datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  validacoes Validacao[]
  createdAt  DateTime    @default(now())
}

model Validacao {
  id          String   @id @default(uuid())
  ideia       String
  consolidado String   // JSON string of consolidated analyses
  metricas    String   // JSON string of execution metrics
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
